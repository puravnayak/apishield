# ============================================================
# APIShield Environment Configuration
# ============================================================
# Copy this file to .env and edit the values for your environment.
# The Go services load this file on startup. Pre-existing system
# environment variables (e.g. from Docker/K8s) always take precedence.
# ============================================================

# --- Gateway ---
GATEWAY_ADDR=:8080
POLICY_CONFIG_PATH=config.yaml
PROXY_TARGET_URL=https://httpbin.org
PPROF_ADDR=:6060

# --- Worker ---
WORKER_ADDR=:8081
WORKER_API_URL=http://localhost:8081

# --- Redis ---
REDIS_ADDR=localhost:6379

# --- PostgreSQL ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/apishield?sslmode=disable

# --- RabbitMQ ---
RABBITMQ_URL=amqp://shield_admin:shield_secret@localhost:5672/

# --- Dashboard (frontend uses its own dashboard/.env) ---
# CORS_ORIGIN=http://localhost:5173
